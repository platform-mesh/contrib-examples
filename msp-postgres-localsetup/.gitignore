.worktrees/

# Runtime state generated by the backing-cluster bring-up (not source).
# `.kube/` : kind cluster's kubeconfig (`kind.kubeconfig`, created by `task kind:up`).
# `bin/`   : any downloaded helper binaries.
# `.kcp/`  : defensive — this variant does NOT run a host-binary kcp (cluster A is the control
#            plane), but ignored for symmetry with the standalone example.
.kube/
bin/
.kcp/
